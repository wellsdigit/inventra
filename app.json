{
  "expo": {
    "name": "stocksense-mobile",
    "slug": "stocksense-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-bg.png",
    "scheme": "stocksensemobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.stocksensemobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.stocksensemobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#346119",
          "image": "./assets/images/logo.png",
          "imageWidth": 100,
          "resizeMode": "contain"
          // "android": {
          //   "image": "./assets/images/logo.png",
          //   "imageWidth": 76,
          //   "size": "contain",
          //   "resizeMode": "contain",
          //   "backgroundColor": "#346119"
          // }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
